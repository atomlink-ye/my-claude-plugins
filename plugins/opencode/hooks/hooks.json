{
  "description": "Clean up the managed OpenCode serve process when the Claude session ends.",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/opencode-companion.mjs\" cleanup --directory \"${CLAUDE_PROJECT_DIR}\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
