{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenCode task output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "directory",
    "status",
    "text_parts",
    "combined_text",
    "file_changes"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "directory": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "queued",
        "running",
        "failed",
        "aborted",
        "unknown"
      ]
    },
    "text_parts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "combined_text": {
      "type": "string"
    },
    "file_changes": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "change": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "message_count": {
      "type": "integer",
      "minimum": 0
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
